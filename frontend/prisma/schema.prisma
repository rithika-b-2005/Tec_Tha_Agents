generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  email          String?        @unique
  phone          String?        @unique
  company        String?
  password       String
  role           String         @default("user")
  platformAccess String[]       @default(["ai-automation"])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refreshTokens  RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Lead {
  id                      String   @id @default(cuid())
  name                    String
  email                   String?
  phone                   String?
  company                 String?
  website                 String?
  title                   String?
  location                String?
  industry                String?
  source                  String?
  linkedinUrl             String?
  score                   Int?
  icpLabel                String?
  companyBio              String?
  automationOpportunity   String?
  leadContext             String?
  outreachLine            String?
  emailSubject            String?
  emailBody               String?
  notes                   String?
  processedAt             DateTime?
  outreachStatus          String?
  needSignals             String?
  contactStatus           String?  @default("never")
  createdAt               DateTime @default(now())
}

model MarketingLead {
  id            String    @id @default(cuid())
  name          String
  email         String?
  phone         String?
  company       String?
  website       String?
  location      String?
  industry      String?
  source        String?
  score         Int?
  icpLabel      String?
  companyBio    String?
  campaignIdea  String?
  contentAngle  String?
  adCopy        String?
  emailSubject  String?
  emailBody     String?
  notes         String?
  processedAt   DateTime?
  linkedinUrl   String?
  needSignals   String?
  contactStatus String?  @default("never")
  createdAt     DateTime  @default(now())
}

model SalesLead {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  website         String?
  location        String?
  industry        String?
  source          String?
  score           Int?
  icpLabel        String?
  companyBio      String?
  painPoint       String?
  salesPitch      String?
  proposalSummary String?
  emailSubject    String?
  emailBody       String?
  notes           String?
  processedAt     DateTime?
  linkedinUrl     String?
  needSignals     String?
  contactStatus   String?  @default("never")
  createdAt       DateTime  @default(now())
}

model CrmContact {
  id              String        @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  website         String?
  location        String?
  industry        String?
  linkedinUrl     String?
  score           Int?
  icpLabel        String?
  needSignals     String?
  companyBio      String?
  emailSubject    String?
  emailBody       String?
  notes           String?
  pipelineStage   String        @default("new")
  sources         String[]
  lastContactedAt DateTime?
  activities      CrmActivity[]
  tasks           CrmTask[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CrmActivity {
  id          String     @id @default(cuid())
  contactId   String
  contact     CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type        String
  summary     String
  createdAt   DateTime   @default(now())
}

model CrmTask {
  id          String     @id @default(cuid())
  contactId   String
  contact     CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title       String
  description String?
  taskType    String     @default("follow_up")  // follow_up|reminder|email_scheduled
  scheduledAt DateTime
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model TestRun {
  id          String       @id @default(cuid())
  platformUrl String
  status      String       @default("pending")
  testCases   String
  browser     String       @default("chromium")
  viewport    String       @default("desktop")
  hasLogin    Boolean      @default(false)
  loginUser   String?
  loginPass   String?
  totalTests  Int          @default(0)
  passed      Int          @default(0)
  failed      Int          @default(0)
  skipped     Int          @default(0)
  duration    Int?
  summary     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  results     TestResult[]
  bugs        TestBug[]
}

model TestResult {
  id          String   @id @default(cuid())
  runId       String
  run         TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  testName    String
  status      String
  duration    Int
  error       String?
  screenshot  String?
  steps       String
  networkLogs String?
  consoleLogs String?
  createdAt   DateTime @default(now())
}

model TestBug {
  id          String   @id @default(cuid())
  runId       String
  run         TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  title       String
  severity    String
  category    String
  steps       String
  expected    String
  actual      String
  screenshot  String?
  aiAnalysis  String
  suggestion  String
  testName    String
  createdAt   DateTime @default(now())
}

model ResearchReport {
  id        String   @id @default(cuid())
  industry  String
  topic     String?
  region    String   @default("Global")
  status    String   @default("pending")
  sections  String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoProject {
  id          String   @id @default(cuid())
  topic       String
  prompt      String?
  voiceText   String?
  style       String   @default("cinematic")
  duration    Int      @default(3)
  voiceId     String   @default("21m00Tcm4TlvDq8ikWAM")
  status      String   @default("queued")
  replicateId String?
  videoUrl    String?
  audioPath   String?
  finalPath   String?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RecruitmentJob {
  id            String                 @id @default(cuid())
  title         String
  description   String
  skills        String[]
  location      String?
  experience    String?
  jobType       String?
  parsedAt      DateTime               @default(now())
  candidates    RecruitmentCandidate[]
  createdAt     DateTime               @default(now())
}

model RecruitmentCandidate {
  id              String          @id @default(cuid())
  jobId           String
  job             RecruitmentJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name            String
  profileUrl      String
  platform        String
  currentRole     String?
  location        String?
  skills          String[]
  snippet         String?
  matchScore      Int?
  matchLabel      String?
  outreachMessage String?
  status          String          @default("new")
  createdAt       DateTime        @default(now())
}

model VoiceCall {
  id           String   @id @default(cuid())
  leadId       String
  leadName     String
  leadPhone    String
  leadCompany  String?
  status       String   @default("initiated") // initiated|in_progress|completed|failed|no_answer
  callSid      String?
  duration     Int?
  transcript   String?
  outcome      String?  // interested|not_interested|callback|voicemail|no_answer
  callbackTime String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Document {
  id        String            @id @default(cuid())
  name      String
  type      String            // pdf | txt | docx
  size      Int
  content   String            // extracted text
  summary   String?
  messages  DocumentMessage[]
  createdAt DateTime          @default(now())
}

model DocumentMessage {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  role       String   // user | assistant
  content    String
  createdAt  DateTime @default(now())
}

model DailyBrief {
  id        String    @id @default(cuid())
  date      String    // YYYY-MM-DD
  news      String?
  weather   String?
  topLeads  String?
  tip       String?
  fullBrief String?
  sentAt    DateTime?
  status    String    @default("pending") // pending|sent|failed
  createdAt DateTime  @default(now())
}

model BrainNote {
  id        String   @id @default(cuid())
  title     String
  content   String
  summary   String?
  tags      String[]
  category  String?  // idea | article | meeting | note | research | other
  source    String?  // url if from web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrowserTask {
  id          String   @id @default(cuid())
  instruction String
  url         String
  status      String   @default("pending") // pending|running|completed|failed
  steps       String?  // JSON array of steps executed
  result      String?  // extracted data / summary
  error       String?
  screenshot  String?  // base64
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id        String     @id @default(cuid())
  sender    String
  text      String
  groupId   String?
  group     ChatGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
}

model ChatGroup {
  id          String        @id @default(cuid())
  name        String
  description String?
  members     String[]
  createdBy   String
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ScheduledClass {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String   // YYYY-MM-DD
  time        String   // HH:MM
  location    String?  // physical address or meeting link
  attendees   String[] // email addresses
  status      String   @default("scheduled") // scheduled|cancelled|completed
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
